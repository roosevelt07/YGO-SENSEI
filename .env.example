# Google Generative AI API Key — get yours at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model used for deck analysis
LLM_MODEL=gemini-1.5-flash

# YGOPRODeck API base URL (no API key required)
YGOPRODECK_BASE_URL=https://db.ygoprodeck.com/api/v7

# Timeout in seconds for outbound HTTP requests
HTTP_TIMEOUT=10
