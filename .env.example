# Anthropic API Key — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Claude model used for deck analysis
LLM_MODEL=claude-haiku-4-5-20251001

# YGOPRODeck API base URL (no API key required)
YGOPRODECK_BASE_URL=https://db.ygoprodeck.com/api/v7

# Timeout in seconds for outbound HTTP requests
HTTP_TIMEOUT=10
